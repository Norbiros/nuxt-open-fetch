{
  "name": "nuxt-open-fetch-docs",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build && npm run twoslash:reset && nuxt build",
    "preview": "nuxt preview",
    "dev": "nuxt dev",
    "generate": "nuxt generate && npm run twoslash:reset && nuxt generate",
    "twoslash:reset": "node -e \"require('node:fs').rmSync('.data', { recursive: true, force: true })\"",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.117",
    "@iconify-json/simple-icons": "^1.2.90",
    "@nuxt/content": "^3.15.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.9.0",
    "@takumi-rs/core": "^2.1.2",
    "better-sqlite3": "^12.11.1",
    "nuxt": "^4.4.8",
    "nuxt-og-image": "^6.7.2",
    "nuxt-open-fetch": "workspace:*"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@nuxt/eslint": "^1.16.0",
    "eslint": "^10.7.0",
    "nuxt-content-twoslash": "^0.4.0",
    "vue-tsc": "^3.3.7"
  }
}
